@model HitsterApp.ViewModels.GameViewModel

<h1>Hitster-spel</h1>

<p>Spelkod: <strong>@Model.JoinCode</strong></p>
<p>Game ID: @Model.GameId</p>
<p>Status: @Model.Status</p>

@if (Model.Status == "finished")
{
    var winner = Model.Players.FirstOrDefault(p => p.PlayerId == Model.WinnerId);

    <h2>Spelet är slut!</h2>
    <p>Vinnare: @winner?.Username</p>

    <form asp-controller="Home" asp-action="StartGame" method="post">
        <button type="submit">Starta nytt spel</button>
    </form>
}
else
{
    <h2>Det är @Model.CurrentPlayerName's tur</h2>
}

<h2>Spelare</h2>

<ul>
@foreach (var player in Model.Players)
{
    <li>
        @player.Username — Poäng: @player.Score — Pengar: @player.Tokens
    </li>
}
</ul>

@{
    var pendingCard = Model.Cards.FirstOrDefault(c => c.State == "pending");

    var currentPlayerCards = Model.Cards
        .Where(c => c.PlayerId == Model.CurrentPlayerId && c.State != "discarded")
        .OrderBy(c => c.ReleaseYear)
        .ToList();
}

<h2>Tidslinjer</h2>

@foreach (var player in Model.Players)
{
    var playerCards = Model.Cards
        .Where(c => c.PlayerId == player.PlayerId && c.State != "discarded")
        .OrderBy(c => c.ReleaseYear)
        .ToList();

    <h3>@player.Username</h3>

    <div class="timeline">

        @if (player.PlayerId == Model.CurrentPlayerId && pendingCard != null && Model.Status != "finished")
        {
            <div class="drop-zone">
                <button type="submit" form="placeCardForm" name="position" value="0">+</button>
            </div>
        }

        @for (int i = 0; i < playerCards.Count; i++)
        {
            <div class="song-card @(playerCards[i].State == "guessed" ? "guessed-card" : "")">
                <strong>@playerCards[i].Title</strong>
                <span>@playerCards[i].Artist</span>
                <small>@playerCards[i].ReleaseYear</small>
                <em>@playerCards[i].State</em>
            </div>

            @if (player.PlayerId == Model.CurrentPlayerId && pendingCard != null && Model.Status != "finished")
            {
                <div class="drop-zone">
                    <button type="submit" form="placeCardForm" name="position" value="@(i + 1)">+</button>
                </div>
            }
        }
    </div>
}

@if (Model.Status != "finished")
{
    <form asp-controller="Home" asp-action="DrawCard" method="post">
        <input type="hidden" name="gameId" value="@Model.GameId" />
        <button type="submit">Dra låt</button>
    </form>
}

@if (Model.Status != "finished")
{
    <form asp-controller="Home" asp-action="EndTurn" method="post">
        <input type="hidden" name="gameId" value="@Model.GameId" />
        <button type="submit">Avsluta tur</button>
    </form>
}

@if (pendingCard != null && Model.Status != "finished")
{
    <h2>Nuvarande låt</h2>

    <div class="pending-area">
        <div class="song-card">
            <strong>@pendingCard.Title</strong>
            <span>@pendingCard.Artist</span>
            <small>@pendingCard.ReleaseYear</small>
        </div>
    </div>

    <form id="placeCardForm" asp-controller="Home" asp-action="PlaceCard" method="post">
        <input type="hidden" name="gameId" value="@Model.GameId" />

        <h3>Extra gissning för +1 peng</h3>

        <label>Låttitel</label>
        <input type="text" name="guessedTitle" placeholder="Valfritt" />

        <label>Artist</label>
        <input type="text" name="guessedArtist" placeholder="Valfritt" />
    </form>

	<form asp-controller="Home" asp-action="SkipCard" method="post">
		<input type="hidden" name="gameId" value="@Model.GameId" />
		<button type="submit">Skippa låtkort (1 peng)</button>
	</form>

	<form asp-controller="Home" asp-action="BuyCard" method="post">
		<input type="hidden" name="gameId" value="@Model.GameId" />
		<button type="submit">Köp låtkort (3 pengar)</button>
	</form>
}

<h2>Låtkort</h2>

<ul>
@foreach (var card in Model.Cards)
{
    <li>
        @card.Title — @card.Artist — @card.ReleaseYear — State: @card.State
    </li>
}
</ul>


<style>
    .timeline {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        padding: 16px;
        border: 2px solid #ddd;
        border-radius: 12px;
        overflow-x: auto;
        min-height: 140px;
    }

    .song-card {
        min-width: 140px;
        max-width: 140px;
        min-height: 100px;
        padding: 12px;
        border: 2px solid #333;
        border-radius: 12px;
        background: white;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        text-align: center;
        box-shadow: 2px 2px 6px rgba(0,0,0,0.15);
    }

    .song-card span,
    .song-card small,
    .song-card em {
        display: block;
    }

    .drop-zone {
        width: 24px;
        transition: width 0.2s ease;
    }

    .drop-zone:hover {
        width: 80px;
    }

    .drop-zone button {
        width: 100%;
        height: 100px;
        border: 2px dashed #777;
        border-radius: 12px;
        background: #f5f5f5;
        cursor: pointer;
        font-size: 24px;
    }

    .drop-zone button:hover {
        background: #e6e6e6;
    }

	.pending-area {
		margin-top: 20px;
		margin-bottom: 30px;
	}

	.guessed-card {
		border-style: dashed;
		background: #fff7d6;
		animation: wobble 1.5s ease-in-out infinite;
	}

	@@keyframes wobble {
		0% { transform: rotate(0deg); }
		25% { transform: rotate(-2deg); }
		50% { transform: rotate(2deg); }
		75% { transform: rotate(-2deg); }
		100% { transform: rotate(0deg); }
	}

</style>